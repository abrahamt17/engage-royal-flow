# ===========================================
# CreatorPay Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets to Git.

# --- Supabase (Required) ---
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# --- Supabase Edge Function Secrets ---
# These are set via `supabase secrets set` or the Supabase dashboard,
# NOT in this .env file. Listed here for reference.
#
# SUPABASE_URL= (auto-set by Supabase)
# SUPABASE_ANON_KEY= (auto-set by Supabase)
# SUPABASE_SERVICE_ROLE_KEY= (auto-set by Supabase)
# SUPABASE_DB_URL= (auto-set by Supabase)
#
# ===== OPENAI API KEY (Required for AI features) =====
# Get your key from: https://platform.openai.com/api-keys
# Set via: supabase secrets set OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_KEY=
#
# PAYPAL_CLIENT_ID= (PayPal sandbox/live client ID)
# PAYPAL_CLIENT_SECRET= (PayPal sandbox/live client secret)
